@model IEnumerable<LibraryManagementSystem.Entity.Category>

@{
    ViewData["Title"] = "Category List";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    int sl = 1;
}



<style>
    /* টেবিল হেডার স্টাইল */
    .table thead th {
        font-size: 0.85rem;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        font-weight: 600;
        border-top: none;
    }

    /* সফট কালার ব্যাজ (Soft Badges) */
    .bg-success-soft {
        background-color: #e8fadf !important;
        color: #71dd37 !important;
        padding: 0.5em 0.8em;
    }

    .bg-danger-soft {
        background-color: #ffe5e5 !important;
        color: #ff3e1d !important;
        padding: 0.5em 0.8em;
    }

    /* হোভার ইফেক্ট */
    .table-hover tbody tr:hover {
        background-color: #f8f9fa;
        transition: 0.3s;
    }

    /* কার্ড শ্যাডো */
    .card {
        border-radius: 0.5rem;
    }

    .shadow-sm {
        box-shadow: 0 .125rem .25rem rgba(0,0,0,.075) !important;
    }

    /* অ্যাকশন বাটন স্টাইল */
    .btn-sm {
        padding: 0.25rem 0.5rem;
        font-size: 0.875rem;
    }
</style>
<div class="container-fluid py-4">
    <div class="card shadow-sm border-0">
        <div class="card-header bg-white py-3 d-flex justify-content-between align-items-center">
            <h5 class="m-0 font-weight-bold text-primary"><i class="fas fa-list me-2"></i>Category List</h5>
            <a asp-action="Create" class="btn btn-primary btn-sm rounded-pill px-3">
                <i class="fas fa-plus me-1"></i> Add New Category
            </a>
        </div>
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-hover align-middle" id="categoryTable">
                    <thead class="table-light">
                        <tr>
                            <th scope="col" class="text-center">#</th>
                            <th scope="col">Category Name</th>
                            <th scope="col">Description</th>
                            <th scope="col" class="text-center">Status</th>
                            <th scope="col" class="text-center">Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr id="row-@item.CategoryId">
                                <td class="text-center fw-bold text-muted">@sl</td>
                                <td>
                                    <span class="fw-bold text-dark">@item.Name</span>
                                    <br />
                                    <small class="text-muted">ID: #@item.CategoryId</small>
                                </td>
                                <td>
                                    <span class="text-truncate d-inline-block" style="max-width: 200px;">
                                        @item.Description
                                    </span>
                                </td>
                                <td class="text-center">
                                    @if (item.IsActive)
                                    {
                                        <span class="badge rounded-pill bg-success-soft text-success">
                                            <i class="fas fa-check-circle me-1"></i> Active
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge rounded-pill bg-danger-soft text-danger">
                                            <i class="fas fa-times-circle me-1"></i> Inactive
                                        </span>
                                    }
                                </td>
                                <td class="text-center">
                                    <div class="btn-group" role="group">
                                        <a asp-controller="Categories" asp-action="Details" asp-route-id="@item.CategoryId"
                                           class="btn btn-outline-info btn-sm me-1" title="View Details">
                                            <i class="fas fa-eye"></i>
                                        </a>
                                        <a asp-action="Edit" asp-route-id="@item.CategoryId"
                                           class="btn btn-outline-warning btn-sm me-1" title="Edit">
                                            Edit
                                        </a>
                                        <a onclick="confirmDelete(@item.CategoryId)"
                                           class="btn btn-outline-danger btn-sm" title="Delete">
                                            <i class="fas fa-trash-alt"></i>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                            sl++;
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>


@section Scripts {

    <script>

                toastr.options = {
          "closeButton": true,
          "debug": false,
          "newestOnTop": false,
          "progressBar": true,
          "positionClass": "toast-top-center",
          "preventDuplicates": false,
          "onclick": null,
          "showDuration": "300",
          "hideDuration": "1000",
          "timeOut": "5000",
          "extendedTimeOut": "1000",
          "showEasing": "swing",
          "hideEasing": "linear",
          "showMethod": "fadeIn",
          "hideMethod": "fadeOut"
        }

        function confirmDelete(id){

            Swal.fire({
                title: "Are you sure?",
                text: "You won't be able to revert this!",
                icon: "warning",
                showCancelButton: true,
                confirmButtonColor: "#3085d6",
                cancelButtonColor: "#d33",
                confirmButtonText: "Yes, delete it!"
            }).then((result) => {
                if (result.isConfirmed) {
                   //window.location.href = '/Categories/DeleteConfirmed?id='+id;

                   $.ajax({
                       url: '/Categories/DeleteAjax',
                       type:'POST',
                       data: {id: id},
                       success: function(repoonse){

                           if(repoonse.success){

                               toastr["success"](repoonse.msg)

                               var table = $('#categoryTable').DataTable();
                               table.row($('#row-'+id)).remove().draw();

                           }
                       },
                       error: function(){

                           alert('An error occurred while deleting the category.');
                       }
                   })

                }
            });
        }
    </script>



    <script>

        $(document).ready(function(){

            $('#categoryTable').DataTable({

                "paging":true,
                "info": true,
                "searching": true,
                "ordering": true,
                "language":{
                    "search": "",
                    "searchPlaceholder": "Search categories..."
                },
                "columnDefs":[
                    { "orderable": false, "target":[4]}
                ]

            });

        });

    </script>


}


