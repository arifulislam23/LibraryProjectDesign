<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin Dashboard | Apex Books</title>

    <!-- 1. Bootstrap 5 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

    <!-- 2. Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />

    <!-- 3. DataTables Bootstrap 5 CSS -->
    <link href="https://cdn.datatables.net/1.13.7/css/dataTables.bootstrap5.min.css" rel="stylesheet">

    <!-- 4. Toastr CSS -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.css" />

    <!-- 5. SweetAlert2 CSS -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.min.css">

    <style>
        body {
            overflow-x: hidden;
            background: #f4f7f6;
        }

        #sidebar {
            min-width: 250px;
            max-width: 250px;
            min-height: 100vh;
            background: #212529;
            color: #fff;
            transition: all 0.3s;
        }

            #sidebar .nav-link {
                color: #adb5bd;
                padding: 15px 20px;
                border-bottom: 1px solid #343a40;
            }

                #sidebar .nav-link:hover, #sidebar .nav-link.active {
                    background: #343a40;
                    color: #fff;
                }

        .main-content {
            width: 100%;
            padding: 20px;
        }
    </style>
</head>
<body>
    <div class="d-flex">
        <!-- Sidebar -->
        <nav id="sidebar">
            <div class="p-4">
                <h3 class="fw-bold text-primary">ApexAdmin</h3>
            </div>
            <ul class="nav flex-column">
                <li class="nav-item"><a asp-action="Index" asp-controller="Home" class="nav-link active"><i class="bi bi-speedometer2 me-2"></i> Dashboard</a></li>
                <li class="nav-item"><a asp-action="Index" asp-controller="Books" class="nav-link"><i class="bi bi-book me-2"></i> Manage Books</a></li>
                <li class="nav-item"><a asp-action="List" asp-controller="Categories" class="nav-link"><i class="bi bi-tags me-2"></i> Categories</a></li>
                <li class="nav-item"><a href="#" class="nav-link text-danger"><i class="bi bi-box-arrow-left me-2"></i> Logout</a></li>
            </ul>
        </nav>

        <main role="main" class="main-content">
            <!-- Top Navbar -->
            <nav class="navbar navbar-expand-lg navbar-light bg-white shadow-sm mb-4 rounded">
                <div class="container-fluid">
                    <button class="btn btn-outline-dark btn-sm" id="sidebarCollapse">
                        <i class="bi bi-list"></i>
                    </button>
                    <div class="ms-auto d-flex align-items-center">
                        <span class="me-3">Welcome, <strong>Admin</strong></span>
                        
                        <img src="~/img/Screenshot-2026-03-08-194358.png" class="rounded-circle" width="35">
                    </div>
                </div>
            </nav>

            @RenderBody()
        </main>
    </div>


    <!-- ১. jQuery  -->
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>

    <!-- ২. Bootstrap Bundle-->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

    <!-- ৩. DataTables JS -->
    <script src="https://cdn.datatables.net/1.13.7/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.7/js/dataTables.bootstrap5.min.js"></script>

    <!-- ৪. SweetAlert2 JS -->
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <!-- ৫. Toastr JS -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.js"></script>

    <!-- ৭. RenderSection -->
    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>